# ============================================================
# SupplyFlow (klant-app) — environment variables
# Kopieer naar .env.local voor lokaal, of zet als "Environment
# Variables" in je Vercel-project. Alle VITE_-waarden komen in de
# browser-bundle, dus zet hier NOOIT een secret/service key neer.
# ============================================================

# --- Supabase (publiek; anon/publishable key is beschermd door RLS) ---
VITE_SUPABASE_URL=https://bjtpnuxjbazlbaoyflcx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# --- Admin-dashboard (ai-ops-hud) ---
# Waar de "OPEN COMMAND CENTER"-knop voor admins naartoe wijst.
# Lokaal:     http://localhost:5181
# Productie:  https://admin.jouwdomein.nl
VITE_HUD_URL=http://localhost:5181

# --- Optioneel / legacy ---
# Wisselkoers-API voor de oude React-admin (nu vervangen door het
# HUD-dashboard, dat een keyless koers-API gebruikt). Leeg laten kan.
VITE_EXCHANGE_API_KEY=
